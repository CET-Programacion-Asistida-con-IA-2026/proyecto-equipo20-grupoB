let activeFilter = "all";

function setFilter(el, f) {
  document.querySelectorAll(".chip").forEach(c => c.classList.remove("active"));
  el.classList.add("active");
  activeFilter = f;
  render();
}

function toggleArea(el) {
  document.querySelectorAll(".area-pill").forEach(p => p.classList.remove("active-area"));
  el.classList.add("active-area");
}

function render() {
  const q = document.getElementById("q").value.toLowerCase();
  const filtered = DATA.filter(j => {
    const fm = activeFilter === "all" || j.type === activeFilter;
    const qm = !q || j.title.toLowerCase().includes(q) || j.company.toLowerCase().includes(q);
    return fm && qm;
  });

  document.getElementById("cnt").textContent = filtered.length;
  const list = document.getElementById("jlist");
  list.innerHTML = "";

  if (!filtered.length) {
    list.innerHTML = '<div class="empty">No encontramos empleos con ese criterio.<br>Probá ajustando los filtros.</div>';
    return;
  }

  filtered.forEach(j => {
    const card = document.createElement("div");
    card.className = "jcard" + (j.feat ? " featured" : "");

    const badgeHtml =
      j.badge === "feat"
        ? '<div class="badge-feat">✦ Destacado</div>'
        : j.badge === "primer"
        ? '<div class="badge-primer">✶ Primer empleo</div>'
        : "";

    const tagsHtml = j.tags
      .map(([t, cls]) => `<span class="jtag ${cls}">${t}</span>`)
      .join("");

    card.innerHTML = `
      ${badgeHtml}
      <div class="jtop">
        <div class="jlogo">${j.emoji}</div>
        <div class="jinfo">
          <div class="jtitle">${j.title}</div>
          <div class="jcompany">${j.company} · ${j.loc}</div>
        </div>
      </div>
      <div class="jtags">${tagsHtml}</div>
      <div class="jdesc">${j.desc}</div>
      <div class="jfoot">
        <div class="jmeta">
          <span>💲 ${j.salary}</span>
          <span>🕐 ${j.posted}</span>
        </div>
        <div class="jactions">
          <button class="btn-save" title="Guardar" onclick="event.stopPropagation()">♡</button>
          <button class="btn-apply">Postularme</button>
        </div>
      </div>
    `;
    list.appendChild(card);
  });
}

render();
